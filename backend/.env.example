DATABASE_URL=postgresql+psycopg://researchflow:researchflow@localhost:5432/researchflow
CORS_ORIGINS=["http://localhost:5173"]

# mock means the app runs without a paid model key.
LLM_PROVIDER=mock
LLM_MODEL=deepseek-chat
LLM_API_KEY=
LLM_BASE_URL=

# Search provider: mock or ddgs.
SEARCH_PROVIDER=mock
SEARCH_MAX_RESULTS=5
SEARCH_REGION=wt-wt
SEARCH_TIMEOUT_SECONDS=10
READER_TIMEOUT_SECONDS=15
READER_MAX_CHARS=6000
UPLOAD_DIR=../data/uploads
UPLOAD_MAX_BYTES=20971520

# RAG settings. mock embeddings are deterministic and need no API key.
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL=mock-embedding-384
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_DIMENSIONS=384
CHUNK_MAX_CHARS=900
CHUNK_OVERLAP_CHARS=120
RAG_TOP_K=5

# DeepSeek example:
# LLM_PROVIDER=deepseek
# LLM_MODEL=deepseek-chat
# LLM_API_KEY=sk-...
# LLM_BASE_URL=https://api.deepseek.com

# Qwen OpenAI-compatible example:
# LLM_PROVIDER=qwen
# LLM_MODEL=qwen-plus
# LLM_API_KEY=sk-...
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
